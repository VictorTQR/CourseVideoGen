{
    "title": "唐诗欣赏",
    "theme": "light",
    "template": "custom",
    "slides": [
        {
            "title": "静夜思",
            "subtitle": "李白",
            "content": [
                "床前明月光，",
                "疑是地上霜。",
                "举头望明月，",
                "低头思故乡。"
            ],
            "script": "这首诗是李白的经典作品，表达了思乡之情。"
        },
        {
            "title": "春晓",
            "subtitle": "孟浩然",
            "content": [
                "春眠不觉晓，",
                "处处闻啼鸟。",
                "夜来风雨声，",
                "花落知多少。"
            ],
            "script": "这首诗描绘了春天早晨的景象。"
        },
        {
            "title": "登鹳雀楼",
            "subtitle": "王之涣",
            "content": [
                "白日依山尽，",
                "黄河入海流。",
                "欲穷千里目，",
                "更上一层楼。"
            ],
            "script": "这首诗表达了积极向上的进取精神。"
        }
    ]
}
